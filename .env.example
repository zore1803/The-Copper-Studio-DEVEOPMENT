PORT=5000
JWT_SECRET=change-this-long-random-secret
CRM_PUBLIC_URL=http://localhost:5173

# Which database backend to use: "supabase" (default) or "mongo".
# Flip this one value to switch the whole app between Supabase and MongoDB.
DB_DRIVER=supabase

# Database: Supabase (hosted Postgres). Find these in your Supabase project under
# Settings -> API. The service-role key is required server-side (it bypasses RLS);
# never expose it to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Needed when DB_DRIVER=mongo, or to run the data migration scripts
# (npm run migrate:supabase / npm run migrate:to-mongo).
# MONGO_URI=mongodb://127.0.0.1:27017/datacircles

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=admin@datacircles.local
SUPERADMIN_PASSWORD=ChangeMe123!

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM=DataCircles CRM <your-email@gmail.com>

CALENDLY_ACCESS_TOKEN=
CALENDLY_WEBHOOK_SIGNING_KEY=


#http://localhost:5000/pricing returns the pricing HTML.
#http://localhost:5000/checkout returns the checkout HTML.
#http://localhost:5173/client-secure-onboarding/access-setup returns the CRM app.


